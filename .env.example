# Optional: public site URL without trailing slash.
NEXT_PUBLIC_APP_URL=

# PostgreSQL. Do not commit real credentials - use .env.local only.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL= postgresql://postgres:Expergo1234@database-1.c5ceycsugota.ap-south-1.rds.amazonaws.com:5432/EWSProd2?schema=public&sslmode=require

# Force SSL on/off for pg Pool. If unset, SSL matches require/prefer or *.rds.amazonaws.com in DATABASE_URL.
# DATABASE_SSL=true
# DATABASE_POOL_MAX=5

# Optional: receive JSON payloads for demo form submissions.
LEADS_WEBHOOK_URL=

# SMTP email for Book Demo confirmations and company notifications.
# Example SMTP providers: Gmail app password, SendGrid SMTP, Mailgun SMTP, AWS SES SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER= info@expergo.tech
SMTP_PASS=
SMTP_FROM="EarlySafe info@expergo.tech"
COMPANY_DEMO_EMAIL= info@expergo.tech

# Optional: receive JSON payloads for newsletter submissions.
# Webhook-only mode works without Postgres.
NEWSLETTER_WEBHOOK_URL=

# Google reCAPTCHA v3 - create keys at https://www.google.com/recaptcha/admin (v3, register your domains).
# When RECAPTCHA_SECRET_KEY is set, newsletter and demo API routes require a valid token from the client.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Optional threshold 0-1 (default 0.5). Lower if legitimate users are blocked.
# RECAPTCHA_MIN_SCORE=0.5
