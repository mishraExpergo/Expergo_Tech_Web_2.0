# Optional: public site URL without trailing slash (only if browser API calls must use an absolute origin)
NEXT_PUBLIC_APP_URL=

# PostgreSQL (RDS). Do not commit real credentials — use .env.local only.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL="postgresql://postgres:Expergo1234@database-1.c5ceycsugota.ap-south-1.rds.amazonaws.com:5432/EWSProd2?schema=public&sslmode=require"

 

# Force SSL on/off for pg Pool (optional). If unset, SSL matches require/prefer or *.rds.amazonaws.com in URL.
# DATABASE_SSL=true

# Optional: receive JSON payloads for demo form submissions (Slack Incoming Webhook, Zapier, etc.)
LEADS_WEBHOOK_URL=

# Newsletter: in production, set DATABASE_URL (and run src/lib/db/schema.sql) and/or NEWSLETTER_WEBHOOK_URL.
# Webhook-only mode works without Postgres.
NEWSLETTER_WEBHOOK_URL= postgresql://postgres:Expergo1234@database-1.c5ceycsugota.ap-south-1.rds.amazonaws.com:5432/EWSProd2?schema=public&sslmode=require

# Google reCAPTCHA v3 — create keys at https://www.google.com/recaptcha/admin (v3, register your domains).
# When RECAPTCHA_SECRET_KEY is set, newsletter and demo API routes require a valid token from the client.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Optional threshold 0–1 (default 0.5). Lower if legitimate users are blocked.
# RECAPTCHA_MIN_SCORE=0.5
